# Power Platform Agent - 环境变量配置示例
# 复制此文件为 .env 并填入实际的值
#
# 此文件包含：
#   1. Dataverse 认证凭证（用于 MCP Server 自动认证）
#   2. LLM API 密钥（用于文档自动更新等 AI 功能）

# ================================
# Dataverse 认证配置（必需）
# ================================
#
# 这些凭证用于 MCP Server 自动连接到 Dataverse 环境
# 配置后，调用 MCP 工具时无需手动提供认证信息
#
# 获取方式：
#   1. 访问 https://portal.azure.com
#   2. 进入 "应用注册" -> "新注册"
#   3. 创建应用程序，获取客户端 ID 和客户端密钥
#   4. 配置 API 权限：Dynamics CRM (user_impersonation)

# 开发环境凭证
DEV_CLIENT_ID=your-client-id-here
DEV_CLIENT_SECRET=your-client-secret-here
DEV_TENANT_ID=your-tenant-id-here

# 测试环境凭证（如果需要）
# TEST_CLIENT_ID=your-test-client-id
# TEST_CLIENT_SECRET=your-test-client-secret
# TEST_TENANT_ID=your-test-tenant-id

# 生产环境凭证（如果需要）
# PROD_CLIENT_ID=your-prod-client-id
# PROD_CLIENT_SECRET=your-prod-client-secret
# PROD_TENANT_ID=your-prod-tenant-id

# ================================
# LLM 配置 (用于文档自动更新等 AI 功能)
# ================================

# LLM 提供商选择: anthropic, zhipu, qwen, openai, doubao
LLM_PROVIDER=anthropic

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 智谱 AI API (如果使用 Zhipu)
# ZHIPUAI_API_KEY=your_zhipuai_api_key_here
# ZHIPU_MODEL=glm-4-flash

# 通义千问 API (如果使用 Qwen)
# DASHSCOPE_API_KEY=sk-your_dashscope_key_here
# QWEN_MODEL=qwen-plus

# OpenAI API (如果使用 OpenAI)
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# 豆包 API (如果使用 Doubao)
# DOUBAO_API_KEY=your_doubao_api_key_here
# DOUBAO_MODEL=doubao-pro-32k
